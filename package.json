{
  "name": "life-pilot-backend",
  "version": "0.0.1",
  "description": "LifePilot NestJS backend with Prisma and Redis",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "npm run format && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\" --fix",
    "postinstall": "npx prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:dev:rm": "docker compose rm -s -f -v",
    "db:dev:up": "docker compose up -d"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.5.5",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.11",
    "@thallesp/nestjs-better-auth": "^2.4.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "pg": "^8.20.0",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.10.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.37",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
