// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id               Int       @id @default(autoincrement())
  title            String
  eventDateAndTime DateTime
  isReminder       Boolean   @default(false)
  eventType        EventType
  priority         Priority
  locationName     String?
  locationAddress  String?
  locationLat      Float?
  locationLng      Float?
  state            State     @default(NO_INICIADO)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  createdBy        Int
  updatedBy        Int?
  deletedBy        Int?
}
