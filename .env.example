# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=development
PORT=3001
SERVER_URL=http://localhost:3001

# ==========================================
# DATABASE - PostgreSQL
# ==========================================
POSTGRES_USER=lifePilotUser
POSTGRES_PASSWORD=lifePilotDB_dev_password
POSTGRES_DB=lifePilotDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://lifePilotUser:lifePilotDB_dev_password@localhost:5432/lifePilotDB?schema=public

# ==========================================
# REDIS CONFIGURATION
# ==========================================
REDIS=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ==========================================
# JWT CONFIGURATION
# ==========================================
JWT_EXPIRATION=15m
JWT_REFRESH_TOKEN=3d
JWT_PRIVATE_KEY=./keys/jwt/private.key
JWT_PUBLIC_KEY=./keys/jwt/public.key

# ==========================================
# BETTER AUTH
# ==========================================
BETTER_AUTH_SECRET=replace_with_output_of__openssl_rand_-base64_32
BETTER_AUTH_URL=http://localhost:3001

# ==========================================
# SECURITY & KEYS
# ==========================================
PLAIN_TEXT=your_plain_text_here_change_in_production
PRIVATE_KEY_SECRET=your_private_key_secret_here_change_in_production

# ==========================================
# AWS S3 CONFIGURATION
# ==========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=eu-west-3
AWS_BUCKET_NAME=your_s3_bucket_name_here
AWS_URL=https://your_bucket_name.s3.region.amazonaws.com/

# ==========================================
# EXTERNAL SERVICES
# ==========================================
RESEND=your_resend_api_key_here

# ==========================================
# APPLICATION SETTINGS
# ==========================================
DEFAULT_COHORT_ID=1

# ==========================================
# RATE LIMITING
# ==========================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ==========================================
# CORS CONFIGURATION
# ==========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
